{
  "name": "household-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first household decision engine",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'wire app-specific dev scripts here'",
    "test": "node scripts/contract-smoke.js > /tmp/household-intelligence-contract-smoke.json && node scripts/full-smoke.js && node scripts/quality-fixtures.js && node scripts/explanation-regression.js && node scripts/calendar-smoke.js && node scripts/telegram-smoke.js",
    "lint": "echo 'wire lint here'",
    "demo": "node scripts/demo-run.js",
    "demo:ha": "HOUSEHOLD_INTELLIGENCE_MODE=ha HOUSEHOLD_INTELLIGENCE_USE_REAL_HA=1 node scripts/demo-run.js",
    "smoke:contracts": "node scripts/contract-smoke.js",
    "smoke:full": "node scripts/full-smoke.js",
    "smoke:ha": "HOUSEHOLD_INTELLIGENCE_MODE=ha HOUSEHOLD_INTELLIGENCE_USE_REAL_HA=1 node scripts/live-ha-smoke.js",
    "smoke:calendar": "node scripts/calendar-smoke.js",
    "smoke:telegram": "node scripts/telegram-smoke.js",
    "test:quality": "node scripts/quality-fixtures.js && node scripts/explanation-regression.js"
  }
}
